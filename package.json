{
  "name": "print-relay-app",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:main\" \"pnpm run dev:renderer\"",
    "dev:main": "tsc --watch -p tsconfig.main.json",
    "dev:renderer": "vite",
    "build": "pnpm run build:main && pnpm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vue-tsc -b && vite build",
    "electron": "cross-env NODE_ENV=development electron .",
    "package": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-builder",
    "package:dir": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-builder --dir"
  },
  "build": {
    "appId": "com.example.print-relay",
    "productName": "打印中转程序",
    "directories": {
      "output": "dist/installer"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "axios": "^1.17.0",
    "net-snmp": "^3.26.3",
    "node-dns-sd": "^1.0.1",
    "ping": "^1.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@types/ping": "^0.4.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.8"
  }
}